#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/backend"

if [ -d ".venv" ]; then
    source .venv/bin/activate
fi

if command -v uv >/dev/null 2>&1; then
    exec uv run uvicorn voice_assistant.main:app --reload --host 0.0.0.0 --port 8000
fi

exec uvicorn voice_assistant.main:app --reload --host 0.0.0.0 --port 8000
